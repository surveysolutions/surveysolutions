<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

  <PreferenceCategory android:key="interview_settings_category">
    <EditTextPreference android:key="GpsReceiveTimeoutSec" app:singleLineTitle="false" />
    <EditTextPreference android:key="GpsDesiredAccuracy" app:singleLineTitle="false" />
    <CheckBoxPreference android:key="ShowLocationOnMap" app:singleLineTitle="false" />
    <CheckBoxPreference android:key="VibrateOnError" app:singleLineTitle="false" />
    <CheckBoxPreference android:key="CommunicationIntegrityValidationIgnore" app:singleLineTitle="false" />
  </PreferenceCategory>

  <PreferenceCategory android:key="connection_settings_category">
    <CheckBoxPreference android:key="AllowSyncWithHq" app:singleLineTitle="false" />
    <EditTextPreference android:key="SyncAddress" app:singleLineTitle="false" />
    <EditTextPreference android:key="HttpResponseTimeout" app:singleLineTitle="false" />
    <EditTextPreference android:key="BufferSize" app:singleLineTitle="false" />
    <EditTextPreference android:key="EventChunkSize" app:singleLineTitle="false" />
  </PreferenceCategory>

  <PreferenceCategory android:key="about_category">
    <Preference android:key="deviceid" app:singleLineTitle="false" />
    <Preference android:key="version" app:singleLineTitle="false" />
  </PreferenceCategory>
</androidx.preference.PreferenceScreen>  

