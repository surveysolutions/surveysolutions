{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "~/*": ["../*"]
    },
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "src/**/*.vue",
    ".vscode/*.json"
  ],
  "exclude": [
    "node_modules",
    "../wwwroot",
    "../obj",
    "../bin",
    "dist"
  ],
  "vueCompilerOptions": {
    "target": 3
  }
}
