@using WB.UI.Shared.Web.Extensions
@using System.Globalization
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    @Html.GenerateFavicon(Url.Static("/img/identity/favicon-hq"))
    <title>@ViewBag.Title</title>
    <partial name="GlobalSettings" />
    <locale component="hq"></locale>
    @RenderSection("scripts", false)
  <script type="module" crossorigin src="/js/hq_vue.js"></script>
  <link rel="modulepreload" crossorigin href="/js/serverValidator.js">
  <link rel="modulepreload" crossorigin href="/js/_plugin-vue_export-helper.js">
  <link rel="modulepreload" crossorigin href="/js/preload-helper.js">
  <link rel="modulepreload" crossorigin href="/js/HubConnectionBuilder.js">
  <link rel="modulepreload" crossorigin href="/js/axios.js">
  <link rel="modulepreload" crossorigin href="/js/lodash.js">
  <link rel="modulepreload" crossorigin href="/js/moment.js">
  <link rel="modulepreload" crossorigin href="/js/config.js">
  <link rel="modulepreload" crossorigin href="/js/questions.js">
  <link rel="modulepreload" crossorigin href="/js/componentsRegistry.js">
  <link rel="modulepreload" crossorigin href="/js/l10n.js">
  <link rel="modulepreload" crossorigin href="/js/compatibility.js">
  <link rel="modulepreload" crossorigin href="/js/main.js">
  <link rel="stylesheet" crossorigin href="/css/serverValidator.css">
  <link rel="stylesheet" crossorigin href="/css/componentsRegistry.css">
  <link rel="stylesheet" crossorigin href="/css/main.css">
  <link rel="stylesheet" crossorigin href="/css/markup-specific.css">
</head>
<body class='wide-navbar'>
    <header>
        <partial name="NavigationBar" />
    </header>
    <partial name="NoticeBar"/>
    @RenderBody()
    <partial name="Footer" />
    <partial name="_Clickjacking"/>
</body>
</html>
